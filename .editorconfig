# EditorConfig

此文件帮助定义和维护跨编辑器和 IDE 的一致编码样式。

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.py]
indent_size = 4

[*.{md,yml,yaml}]
indent_size = 2

[*.bat]
end_of_line = crlf

[Makefile]
indent_style = tab
